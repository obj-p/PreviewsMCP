#!/usr/bin/env bash
set -euo pipefail

# Lint the staged files with the hermetic, Bazel-pinned tools (the same ones the
# merge gate uses), so a local commit and the gate can never disagree on tool
# versions. First run on a fresh checkout fetches the tool binaries, then caches.
cd "$(git rev-parse --show-toplevel)"
exec ./tools/bazel run --ui_event_filters=-info --noshow_progress //tools/lint:staged
