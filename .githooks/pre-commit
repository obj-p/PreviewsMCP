#!/usr/bin/env bash
set -euo pipefail

if ! command -v swift-format &>/dev/null; then
    echo "error: swift-format not found. Install with: brew bundle" >&2
    exit 1
fi

# Lint only staged .swift files
staged=$(git diff --cached --name-only --diff-filter=ACM -- '*.swift')
if [ -z "$staged" ]; then
    exit 0
fi

echo "$staged" | xargs swift-format lint --strict 2>&1
