{
  "settleSeconds": 2,
  "maxIterations": 80,
  "rules": [
    { "match": "Welcome", "actions": [
      { "op": "key", "key": "return" }
    ]},
    { "match": "Select Your Country", "actions": [
      { "op": "clickByText", "text": "Select Your Country" },
      { "op": "wait", "seconds": 2 },
      { "op": "type", "text": "united states" },
      { "op": "wait", "seconds": 2 },
      { "op": "clickByText", "text": "United States" },
      { "op": "wait", "seconds": 1 },
      { "op": "modifiedKey", "modifier": "shift", "key": "tab" },
      { "op": "wait", "seconds": 1 },
      { "op": "key", "key": "space" }
    ]},
    { "match": "Transfer Your Data", "actions": [
      { "op": "clickByText", "text": "Set up as new" },
      { "op": "wait", "seconds": 2 },
      { "op": "clickByText", "text": "Continue" }
    ]},
    { "match": "Written and Spoken Languages", "actions": [
      { "op": "clickByText", "text": "Continue" }
    ]},
    { "match": "Accessibility", "actions": [
      { "op": "clickByText", "text": "Not Now" }
    ]},
    { "match": "Data & Privacy", "actions": [
      { "op": "clickByText", "text": "Continue" }
    ]},
    { "match": "Create a Mac Account", "actions": [
      { "op": "clickByText", "text": "Full Name" },
      { "op": "wait", "seconds": 1 },
      { "op": "type", "text": "admin" },
      { "op": "key", "key": "tab" },
      { "op": "key", "key": "tab" },
      { "op": "type", "text": "vzvz" },
      { "op": "clickByText", "text": "Verify Password" },
      { "op": "type", "text": "vzvz" },
      { "op": "wait", "seconds": 1 },
      { "op": "clickByText", "text": "Continue" }
    ]},
    { "match": "Sign In to Your Apple Account", "actions": [
      { "op": "clickByText", "text": "Other Sign-In Options" },
      { "op": "wait", "seconds": 2 },
      { "op": "clickByText", "text": "Sign in Later in Settings" },
      { "op": "wait", "seconds": 2 },
      { "op": "clickByText", "text": "Skip" }
    ]},
    { "match": "Terms and Conditions", "actions": [
      { "op": "clickByText", "text": "Agree" },
      { "op": "wait", "seconds": 2 },
      { "op": "clickByText", "text": "Agree" }
    ]},
    { "match": "Age Range", "actions": [
      { "op": "clickByText", "text": "Adult" },
      { "op": "wait", "seconds": 1 },
      { "op": "clickByText", "text": "Continue" }
    ]},
    { "match": "Location Services", "actions": [
      { "op": "clickByText", "text": "Continue" },
      { "op": "wait", "seconds": 2 },
      { "op": "clickByText", "text": "Don't Use" }
    ]},
    { "match": "Time Zone", "actions": [
      { "op": "clickByText", "text": "Continue" }
    ]},
    { "match": "Analytics", "actions": [
      { "op": "clickByText", "text": "Continue" }
    ]},
    { "match": "Screen Time", "actions": [
      { "op": "clickByText", "text": "Set Up Later" }
    ]},
    { "match": "FileVault", "actions": [
      { "op": "clickByText", "text": "Not Now" },
      { "op": "wait", "seconds": 2 },
      { "op": "clickByText", "text": "Continue" }
    ]},
    { "match": "Choose Your Look", "actions": [
      { "op": "clickByText", "text": "Continue" }
    ]},
    { "match": "Update Mac", "actions": [
      { "op": "clickByText", "text": "Continue" }
    ]},
    { "match": "Language", "actions": [
      { "op": "key", "key": "return" }
    ]},
    { "match": "Finder", "terminal": true, "actions": [] },
    { "match": "Get Started", "actions": [
      { "op": "clickByText", "text": "Get Started" }
    ]},
    { "match": "Continue", "actions": [
      { "op": "key", "key": "return" }
    ]}
  ]
}
