build --apple_platform_type=macos
build --xcode_version=26.2
build --macos_minimum_os=14.0
build --ios_minimum_os=14.0
build --verbose_failures
build --workspace_status_command=bazel/workspace_status.sh
build --disk_cache=~/.cache/bazel-disk
build --experimental_disk_cache_gc_max_size=50G

test --test_env=PREVIEWSMCP_REPO_ROOT

try-import %workspace%/.bazelrc.user
